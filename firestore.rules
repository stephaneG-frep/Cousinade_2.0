rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userFamilyId() {
      return userDoc().data.familyId;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function sameFamily(familyId) {
      return isSignedIn() &&
        userFamilyId() != null &&
        userFamilyId() == familyId &&
        familyId == 'primary';
    }

    function postFamilyId(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data.familyId;
    }

    function postAuthorId(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data.authorId;
    }

    function conversationFamilyId(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data.familyId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || resource.data.familyId == userFamilyId());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (
          isAdmin() &&
          resource.data.familyId == userFamilyId() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['familyId', 'role'])
        )
      );
    }

    match /families/{familyId} {
      allow read: if isSignedIn() && familyId == 'primary';
      allow create: if isSignedIn() &&
        familyId == 'primary' &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if familyId == 'primary' && (
        sameFamily(familyId) || (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membersCount', 'createdBy', 'inviteCode', 'name'])
        )
      );
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if sameFamily(resource.data.familyId);
      allow update: if sameFamily(resource.data.familyId) && (
        request.auth.uid == resource.data.authorId ||
        (
          isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'imageUrl',
            'videoUrl',
            'videoThumbnailUrl'
          ])
        ) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount'])
      );
      allow delete: if sameFamily(resource.data.familyId) && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );
      allow create: if sameFamily(request.resource.data.familyId);

      match /likes/{userId} {
        allow read, write: if isSignedIn() && sameFamily(postFamilyId(postId));
      }
    }

    match /comments/{commentId} {
      allow read, update: if isSignedIn() && sameFamily(postFamilyId(resource.data.postId));
      allow delete: if isSignedIn() &&
        sameFamily(postFamilyId(resource.data.postId)) && (
          request.auth.uid == resource.data.authorId ||
          request.auth.uid == postAuthorId(resource.data.postId) ||
          isAdmin()
        );
      allow create: if isSignedIn() && sameFamily(postFamilyId(request.resource.data.postId));
    }

    match /conversations/{conversationId} {
      allow read, update: if isSignedIn() && sameFamily(resource.data.familyId);
      allow create: if isSignedIn() && sameFamily(request.resource.data.familyId);
    }

    match /messages/{messageId} {
      allow read, update: if isSignedIn() && sameFamily(conversationFamilyId(resource.data.conversationId));
      allow create: if isSignedIn() && sameFamily(conversationFamilyId(request.resource.data.conversationId));
    }

    match /events/{eventId} {
      allow read, update: if sameFamily(resource.data.familyId);
      allow create: if sameFamily(request.resource.data.familyId);
      allow delete: if sameFamily(resource.data.familyId) && (
        request.auth.uid == resource.data.createdBy || isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
  }
}
